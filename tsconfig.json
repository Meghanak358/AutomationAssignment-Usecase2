{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,

    "types": [
      "node",
      "@playwright/test"
    ],

    "lib": [
      "ES2020",
      "DOM"
    ],

    "forceConsistentCasingInFileNames": true,
    "noEmit": true
  },

  "include": [
    "pages/**/*.ts",
    "tests/**/*.ts",
    "playwright.config.ts"
  ],

  "exclude": [
    "node_modules",
    "test-results",
    "playwright-report"
  ]
}